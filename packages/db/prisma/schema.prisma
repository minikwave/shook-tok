generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(uuid())
  discordUserId String   @unique
  username      String?
  avatarUrl     String?
  pointsBalance Int      @default(0)

  sentPokes     Poke[]   @relation("SentPokes")
  receivedPokes Poke[]   @relation("ReceivedPokes")
  pointLedgers  PointLedger[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Server {
  id               String   @id @default(uuid())
  discordGuildId   String   @unique
  name             String?
  defaultChannelId String?

  pokes          Poke[]
  pointLedgers   PointLedger[]
  relationships  Relationship[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Poke {
  id         String     @id @default(uuid())
  serverId   String
  senderId   String
  receiverId String

  emotion     String?
  message     String?
  status      PokeStatus @default(PENDING)

  createdAt   DateTime  @default(now())
  respondedAt DateTime?

  server   Server @relation(fields: [serverId], references: [id], onDelete: Cascade)
  sender   User   @relation("SentPokes", fields: [senderId], references: [id], onDelete: Cascade)
  receiver User   @relation("ReceivedPokes", fields: [receiverId], references: [id], onDelete: Cascade)

  @@index([serverId])
  @@index([senderId])
  @@index([receiverId])
  @@index([createdAt])
}

enum PokeStatus {
  PENDING
  RESPONDED
  EXPIRED
  CANCELLED
}

model PointLedger {
  id       String @id @default(uuid())
  userId   String
  serverId String
  amount   Int
  reason   String
  refType  String?
  refId    String?

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  server Server @relation(fields: [serverId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([serverId])
  @@index([createdAt])
}

model Relationship {
  id                String    @id @default(uuid())
  serverId          String
  userAId           String
  userBId           String

  streakCount       Int       @default(0)
  totalInteractions Int       @default(0)
  lastInteractionAt DateTime?
  lastStreakDate    DateTime?

  server Server @relation(fields: [serverId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([serverId, userAId, userBId])
  @@index([serverId])
  @@index([userAId])
  @@index([userBId])
}
