{
  "name": "@shook/bot",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "node --import tsx src/index.ts",
    "commands:register": "node --import tsx src/register-commands.ts",
    "invite": "node --import tsx src/scripts/print-invite.ts",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@prisma/client": "^6.1.0",
    "@shook/db": "workspace:*",
    "@shook/shared": "workspace:*",
    "discord.js": "^14.16.3",
    "dotenv": "^16.4.7"
  },
  "devDependencies": {
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
